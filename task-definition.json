{
  "family": "jwt-pizza-service-new",
  "networkMode": "awsvpc",
  "containerDefinitions": [
    {
      "name": "jwt-pizza-service",
      "image": "REPLACE_ME_WITH_ECR_URI",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "DB_HOSTNAME", "value": "REPLACE_DB_HOST" },
        { "name": "DB_USERNAME", "value": "REPLACE_DB_USER" },
        { "name": "DB_PASSWORD", "value": "REPLACE_DB_PASSWORD" },
        { "name": "DB_NAME", "value": "REPLACE_DB_NAME" },
        {
          "name": "METRICS_ENDPOINT_URL",
          "value": "REPLACE_METRICS_ENDPOINT_URL"
        },
        {
          "name": "METRICS_ACCOUNT_ID_KEY",
          "value": "REPLACE_METRICS_ACCOUNT_ID_KEY"
        },
        { "name": "METRICS_API_KEY", "value": "REPLACE_METRICS_API_KEY" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/jwt-pizza-service",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ],
  "executionRoleArn": "arn:aws:iam::897920190853:role/jwt-pizza-ecs-new",
  "taskRoleArn": "arn:aws:iam::897920190853:role/jwt-pizza-ecs-new",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "runtimePlatform": {
    "cpuArchitecture": "ARM64",
    "operatingSystemFamily": "LINUX"
  }
}
